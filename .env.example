# Ollama endpoint — on macOS/Windows this is your host machine;
# on Linux you may need to set this to the bridge network gateway.
SANCTUM_OLLAMA_HOST=http://host.docker.internal:11434

# OpenRouter (optional — leave empty to disable cloud runtime)
SANCTUM_OPENROUTER_API_KEY=

# Logging verbosity: DEBUG | INFO | WARNING | ERROR
SANCTUM_LOG_LEVEL=INFO

# Whether to log full prompts/responses in the task log (noisy; off by default)
SANCTUM_LOG_TASK_PROMPTS=false
SANCTUM_LOG_TASK_RESPONSES=false
